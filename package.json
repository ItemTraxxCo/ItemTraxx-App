{
  "name": "itemtraxx-code",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=22.15.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "npm run build && wrangler dev",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "security:audit": "bash ./scripts/security-audit.sh",
    "security:gate": "npm run security:audit",
    "security:sbom": "bash ./scripts/generate-sbom.sh",
    "perf:budget": "node ./scripts/check-bundle-budget.mjs",
    "perf:css-boundary": "node ./scripts/check-public-css-boundary.mjs",
    "perf:initial": "node ./scripts/check-initial-load-budget.mjs",
    "perf:initial:report": "node ./scripts/check-initial-load-budget.mjs --report-only",
    "perf:images": "node ./scripts/check-image-budget.mjs",
    "perf:report": "node ./scripts/perf-report.mjs",
    "worker:types": "cd cloudflare/edge-proxy && wrangler types worker-configuration.d.ts --config wrangler.toml --env-file .dev.vars.example --strict-vars false",
    "worker:types:check": "cd cloudflare/edge-proxy && wrangler types worker-configuration.d.ts --config wrangler.toml --env-file .dev.vars.example --strict-vars false --check",
    "worker:typecheck": "npm run worker:types:check && tsc -p cloudflare/edge-proxy/tsconfig.json",
    "worker:test": "deno test --no-check --frozen cloudflare/edge-proxy/src/*_test.ts",
    "docs:edge-schemas": "node ./scripts/generate-edge-schemas.mjs",
    "docs:edge-openapi": "node ./scripts/generate-edge-schemas.mjs",
    "docs:edge-reference": "node ./scripts/generate-edge-reference.mjs",
    "devops:check:edge-coverage": "node ./scripts/check-edge-function-coverage.mjs",
    "devops:check:edge-contract-drift": "node ./scripts/check-edge-contract-drift.mjs",
    "devops:check:sql-coupling": "node ./scripts/check-sql-function-coupling.mjs",
    "devops:bump-hub-sha": "node ./scripts/bump-devops-hub-sha.mjs",
    "analytics:report": "node ./scripts/vercel-analytics-agent.mjs",
    "email:preview": "node ./scripts/generate-email-previews.mjs",
    "deploy:supabase:functions": "python3 ./scripts/deploy-supabase-functions.py",
    "deploy:cloudflare:worker": "bash ./scripts/deploy-cloudflare-worker.sh",
    "deploy": "npm run build && wrangler deploy"
  },
  "dependencies": {
    "@sentry/vue": "^10.64.0",
    "@supabase/supabase-js": "^2.110.2",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "jsbarcode": "^3.12.3",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "posthog-js": "^1.399.0",
    "vue": "^3.5.39",
    "vue-router": "^4.6.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.43.1",
    "@cyclonedx/cyclonedx-npm": "6.0.0",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/tsconfig": "^0.9.1",
    "supabase": "2.109.1",
    "typescript": "~6.0.3",
    "vite": "^8.1.4",
    "vue-tsc": "^3.3.7",
    "wrangler": "4.107.1"
  },
  "overrides": {
    "esbuild": "0.28.1",
    "tar": "^7.5.10",
    "protobufjs@<=8.2.0": "8.2.0",
    "ws": "^8.20.1",
    "dompurify": "3.4.11",
    "undici": "7.28.0"
  }
}
