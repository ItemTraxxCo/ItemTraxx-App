{
  "name": "itemtraxx-code",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "security:audit": "bash ./scripts/security-audit.sh",
    "security:gate": "npm audit --audit-level=high && npm run security:audit",
    "security:sbom": "bash ./scripts/generate-sbom.sh",
    "perf:budget": "node ./scripts/check-bundle-budget.mjs",
    "perf:images": "node ./scripts/check-image-budget.mjs",
    "perf:report": "node ./scripts/perf-report.mjs",
    "docs:edge-schemas": "node ./scripts/generate-edge-schemas.mjs",
    "docs:edge-openapi": "node ./scripts/generate-edge-schemas.mjs",
    "docs:edge-reference": "node ./scripts/generate-edge-reference.mjs",
    "analytics:report": "node ./scripts/vercel-analytics-agent.mjs",
    "deploy:supabase:functions": "python3 ./scripts/deploy-supabase-functions.py",
    "deploy:cloudflare:worker": "bash ./scripts/deploy-cloudflare-worker.sh"
  },
  "dependencies": {
    "@posthog/react": "^1.9.0",
    "@sentry/vue": "^10.50.0",
    "@supabase/supabase-js": "^2.104.1",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "jsbarcode": "^3.12.3",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "posthog-js": "^1.372.1",
    "supabase": "2.95.3",
    "vue": "^3.5.33",
    "vue-router": "^4.6.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/tsconfig": "^0.9.1",
    "rollup": "^4.60.2",
    "typescript": "~6.0.3",
    "vite": "^8.0.10",
    "vue-tsc": "^3.2.7",
    "wrangler": "^4.85.0",
    "zod-to-json-schema": "^3.25.2"
  },
  "overrides": {
    "tar": "^7.5.10",
    "tar@<=7.5.11": "7.5.11",
    "protobufjs@<=8.0.1": "8.0.1"
  }
}
